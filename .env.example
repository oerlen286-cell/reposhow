# Copy this file to .env.local in the project root (server.py loads .env.local via python-dotenv).
# At least one TTS provider key is required
# Gemini (recommended, supports multi-speaker TTS)
GEMINI_API_KEY=your-gemini-api-key

# DashScope (Chinese TTS fallback via Alibaba CosyVoice)
DASHSCOPE_API_KEY=your-dashscope-api-key

# OpenAI (used for narration script generation via GPT + Whisper subtitle alignment)
OPENAI_API_KEY=your-openai-api-key
